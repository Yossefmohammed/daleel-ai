# ══════════════════════════════════════════════════════════════════════════════
# Daleel AI - Security-First .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── SECRETS & API KEYS (CRITICAL - NEVER COMMIT) ──────────────────────────────
.env
.env.local
.env.*.local
.streamlit/secrets.toml
*.key
*.pem
secrets/
credentials/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
ENV/
env/
.venv/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Databases & Caches ────────────────────────────────────────────────────────
db/*.sqlite3
db/chroma.sqlite3
*.db
*.sqlite
.chroma/
chroma_data/

# ── Logs & Temporary Files ────────────────────────────────────────────────────
*.log
logs/
temp/
tmp/
*.tmp

# ── User Data (should be in persistent storage, not git) ──────────────────────
chat_history.csv
feedback.csv
data/jobs_combined.csv
data/jobs_*.csv
uploads/

# ── Model Artifacts (large files) ─────────────────────────────────────────────
*.bin
*.pkl
*.h5
*.onnx
models/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS Generated ──────────────────────────────────────────────────────────────
Thumbs.db
.DS_Store